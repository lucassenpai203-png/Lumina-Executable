{
    "$schema": "../node_modules/@tauri-apps/cli/schema.json",
    "identifier": "com.lucas.lumina",
    "productName": "Lúmina",
    "version": "0.1.0",
    "build": {
        "beforeBuildCommand": "npm run build",
        "beforeDevCommand": "npm start",
        "frontendDist": "../dist",
        "devUrl": "http://localhost:1420"
    },
    "app": {
        "windows": [
            {
                "title": "Lúmina Desktop",
                "width": 1200,
                "height": 800
            }
        ]
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [ "icons/icon.png" ]
    }
}
