{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "com.lucas.lumina",
  "productName": "Lúmina",
  "version": "0.2.0",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "pnpm run dev",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Lúmina — Cabina Virtual",
        "width": 1080,
        "height": 720,
        "minWidth": 1080,
        "minHeight": 720,
        "maxWidth": 1080,
        "maxHeight": 720,
        "decorations": true,
        "transparent": false,
        "resizable": false,
        "center": true,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": []
  },
  "plugins": {
    "opener": {}
  }
}
